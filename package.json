{
  "name": "@techiesgult/cortex-mem",
  "version": "0.1.0",
  "description": "Open-source AI memory engine with a living knowledge graph. MCP server for Claude.",
  "author": "Aravindargutus",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Aravindargutus/cortex-mem.git"
  },
  "homepage": "https://github.com/Aravindargutus/cortex-mem#readme",
  "bugs": {
    "url": "https://github.com/Aravindargutus/cortex-mem/issues"
  },
  "bin": {
    "cortex-mem": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/bench.*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js serve",
    "setup": "node dist/cli.js setup",
    "typecheck": "tsc --noEmit",
    "bench": "npm run build && node dist/bench.js"
  },
  "keywords": [
    "ai",
    "memory",
    "mcp",
    "claude",
    "knowledge-graph",
    "llm",
    "agent",
    "cortex"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
